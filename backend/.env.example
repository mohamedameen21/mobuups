NODE_ENV=development
PORT=4000

# CORS: which frontend origin is allowed to call this API with credentials
CORS_ORIGIN=http://localhost:5173

# JWT secrets - generate your own with: openssl rand -base64 32
# Never reuse the same secret for both; keep these out of git (see .env, which is gitignored)
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Added once we start the Prisma/Postgres piece - not needed yet
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/product_store
