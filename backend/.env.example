NODE_ENV=development
PORT=4000

# CORS: which frontend origin is allowed to call this API with credentials
CORS_ORIGIN=http://localhost:5173

# JWT access token secret - generate your own with: openssl rand -base64 32
# Refresh tokens are opaque, DB-stored (see RefreshToken model), so they don't use a JWT secret
JWT_ACCESS_SECRET=change_me_access
JWT_ACCESS_EXPIRES=15m

# Prisma/Postgres connection string - adjust user/password to match your local setup
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/product_store
