generator client {
  provider           = "prisma-client"
  output             = "../src/generated/prisma"
  moduleFormat       = "esm"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}
