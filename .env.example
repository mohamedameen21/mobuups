# User and Group ID configuration (matches host user permissions on mounted volumes)
PUID=1000
PGID=1000

# Port Configurations
FRONTEND_PORT=8080
BACKEND_PORT=4000
DB_PORT=5432

# Database Credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=mobupps_db

# Security & Domain Configuration
NODE_ENV=production
JWT_ACCESS_SECRET=super-secret-access-token-key-change-in-prod-12345
CORS_ORIGIN=http://localhost:8080
